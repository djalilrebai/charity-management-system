// ============================================
// Deep-Charity / Association Management System
// Prisma Schema — MySQL
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. المصادقة والصلاحيات (Auth & Roles)
// ============================================

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique // admin, secretary, accountant, viewer
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  users User[]

  @@map("roles")
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  passwordHash String    @map("password_hash")
  roleId       Int       @map("role_id")
  memberId     Int?      @unique @map("member_id")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  role      Role       @relation(fields: [roleId], references: [id])
  member    Member?    @relation(fields: [memberId], references: [id])
  documents Document[]
  incomes   Income[]   @relation("IncomeCreatedBy")
  incomesUpdated Income[] @relation("IncomeUpdatedBy")
  expenses  Expense[]  @relation("ExpenseCreatedBy")
  expensesUpdated Expense[] @relation("ExpenseUpdatedBy")
  auditLogs AuditLog[]
  familyActivitiesCreated FamilyActivity[] @relation("FamilyActivityCreatedBy")

  @@index([roleId])
  @@map("users")
}

// ============================================
// 2. العائلات المستفيدة (Families & Children)
// ============================================

enum Categorie {
  A
  B
  C
}

enum HousingStatus {
  RENT // كراء
  OWN // ملك
  OTHER // أخرى
}

enum Sexe {
  MALE
  FEMALE
}

model Family {
  id             Int           @id @default(autoincrement())
  numSequentiel  String        @unique @map("num_sequentiel")
  nom            String // اسم الأرملة
  prenom         String // اللقب
  dateNaissance  DateTime      @map("date_naissance")
  nationalId     String?       @unique @map("national_id") // رقم بطاقة التعريف الوطنية
  telephone      String
  adresse        String
  quartier       String? // الحي — للفلترة
  categorie      Categorie
  salaire        Decimal       @db.Decimal(10, 2)
  housingStatus  HousingStatus @default(OTHER) @map("housing_status")
  orphansCount   Int           @default(0) @map("orphans_count")
  notes          String?       @db.Text
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at") // soft delete

  children          Child[]
  documents         Document[]
  familyActivities  FamilyActivity[]

  @@index([nom, prenom])
  @@index([categorie])
  @@index([quartier])
  @@map("families")
}

model Child {
  id            Int       @id @default(autoincrement())
  familyId      Int       @map("family_id")
  nom           String
  sexe          Sexe
  dateNaissance DateTime  @map("date_naissance")
  situation     String? // الوضعية (يتيم، معاق...)
  anneeEtude    String?   @map("annee_etude") // السنة الدراسية
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  enrollments Enrollment[]
  attendances Attendance[]

  @@index([familyId])
  @@map("children")
}

// أرشفة الوثائق (شهادة وفاة، بطاقة هوية، شهادة إقامة...)
model Document {
  id         Int      @id @default(autoincrement())
  familyId   Int      @map("family_id")
  type       String // death_certificate, national_id_card, residence_certificate...
  filePath   String   @map("file_path")
  uploadedBy Int      @map("uploaded_by")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  family     Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  uploadedByUser User @relation(fields: [uploadedBy], references: [id])

  @@index([familyId])
  @@map("documents")
}

// ============================================
// 3. الأنشطة والمساعدات (Activities)
// ============================================

model Activity {
  id          Int      @id @default(autoincrement())
  name        String // قفة رمضان، كسوة العيد، أضحية العيد...
  type        String? // مالي / عيني
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  familyActivities FamilyActivity[]

  @@map("activities")
}

model FamilyActivity {
  id         Int       @id @default(autoincrement())
  familyId   Int       @map("family_id")
  activityId Int       @map("activity_id")
  date       DateTime
  quantity   Int?      @default(1) // الكمية (مثلاً: عدد القفف)
  value      Decimal?  @db.Decimal(10, 2) // القيمة المالية إن وجدت
  notes      String?
  createdBy  Int?      @map("created_by") // من سجّل هذي الاستفادة
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")

  family        Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  activity      Activity @relation(fields: [activityId], references: [id])
  createdByUser User?  @relation("FamilyActivityCreatedBy", fields: [createdBy], references: [id])

  @@index([familyId])
  @@index([activityId])
  @@index([date])
  @@map("family_activities")
}

// ============================================
// 4. دروس الدعم والتعليم القرآني
// ============================================

enum ClassType {
  SOUTIEN // دعم مدرسي
  CORANIQUE // تعليم قرآني
}

model ClassRoom {
  id       Int       @id @default(autoincrement())
  name     String
  teacher  String
  type     ClassType
  niveau   String? // المستوى
  horaire  String? // التوقيت
  notes    String? // ملاحظات
  deletedAt DateTime? @map("deleted_at")

  enrollments Enrollment[]
  attendances Attendance[]

  @@map("classes")
}

model Enrollment {
  id               Int      @id @default(autoincrement())
  childId          Int      @map("child_id")
  classId          Int      @map("class_id")
  dateInscription  DateTime @default(now()) @map("date_inscription")
  status           String   @default("ACTIVE") // ACTIVE / STOPPED

  child Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  class ClassRoom @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([childId, classId])
  @@map("enrollments")
}

model Attendance {
  id         Int      @id @default(autoincrement())
  childId    Int      @map("child_id")
  classId    Int      @map("class_id")
  lessonDate DateTime @map("lesson_date")
  present    Boolean  @default(true)

  child Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  class ClassRoom @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([childId, lessonDate])
  @@index([classId, lessonDate])
  @@map("attendance")
}

// ============================================
// 5. المحاسبة (Income & Expenses)
// ============================================

model Income {
  id          Int       @id @default(autoincrement())
  date        DateTime
  amount      Decimal   @db.Decimal(12, 2)
  category    String // تبرع، زكاة، اشتراكات، إعانة بلدية، وقف...
  reference   String? // رقم الوصل/السند، مثلاً DON-2026-001
  description String?   @db.Text
  createdBy   Int       @map("created_by")
  updatedBy   Int?      @map("updated_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  createdByUser User  @relation("IncomeCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("IncomeUpdatedBy", fields: [updatedBy], references: [id])

  @@index([date])
  @@index([category])
  @@map("income")
}

model Expense {
  id          Int       @id @default(autoincrement())
  date        DateTime
  amount      Decimal   @db.Decimal(12, 2)
  category    String // قفة رمضان، كسوة، إيجار، فواتير...
  reference   String? // رقم الوصل/السند، مثلاً EXP-2026-015
  description String?   @db.Text
  createdBy   Int       @map("created_by")
  updatedBy   Int?      @map("updated_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  createdByUser User  @relation("ExpenseCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("ExpenseUpdatedBy", fields: [updatedBy], references: [id])

  @@index([date])
  @@index([category])
  @@map("expenses")
}

// ============================================
// 6. أعضاء المكتب (Members)
// ============================================

model Member {
  id            Int       @id @default(autoincrement())
  nom           String
  prenom        String
  telephone     String
  dateNaissance DateTime  @map("date_naissance")
  niveauEtude   String?   @map("niveau_etude")
  profession    String?
  poste         String // رئيس، نائب رئيس، أمين مال، كاتب عام...
  dateAdhesion  DateTime  @default(now()) @map("date_adhesion")
  deletedAt     DateTime? @map("deleted_at")

  user User?

  @@map("members")
}

// ============================================
// 7. سجل العمليات (Audit Log)
// ============================================

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  action    String // CREATE, UPDATE, DELETE
  tableName String   @map("table_name")
  recordId  Int      @map("record_id")
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([userId])
  @@map("audit_logs")
}
